{
  "functions": {
    "api/search.js":          { "maxDuration": 10 },
    "api/send-dedication.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/for/:hash", "destination": "/for-send.html?h=:hash" },
    { "source": "/for-send", "destination": "/for-send.html" },
    { "source": "/inbox", "destination": "/for-inbox.html" },
    { "source": "/for-inbox", "destination": "/for-inbox.html" },
    { "source": "/for", "destination": "/for.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms",   "destination": "/terms.html" },
    { "source": "/", "destination": "/create.html" }
  ]
}
